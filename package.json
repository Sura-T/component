{
  "name": "group-monorepo-system",
  "version": "1.0.0",
  "private": true,
  "description": "Modular monorepo with shared UI, utils, and feature packages.",
  "workspaces": [
    "packages/*",
    "systems/*/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
